{
  "version": 2,
  "builds": [
    { "src": "omni-school-backend/server.js", "use": "@vercel/node" },
    { "src": "client/package.json", "use": "@vercel/static-build" }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "omni-school-backend/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "client/$1",
      "check": true
    }
  ]
}
